600","line":395,"column":25,"nodeType":"601","endLine":395,"endColumn":64},{"ruleId":"599","severity":1,"message":"600","line":398,"column":25,"nodeType":"601","endLine":398,"endColumn":64},{"ruleId":"599","severity":1,"message":"600","line":401,"column":25,"nodeType":"601","endLine":401,"endColumn":64},{"ruleId":"599","severity":1,"message":"600","line":404,"column":25,"nodeType":"601","endLine":404,"endColumn":64},{"ruleId":"599","severity":1,"message":"600","line":407,"column":25,"nodeType":"601","endLine":407,"endColumn":64},{"ruleId":"599","severity":1,"message":"600","line":410,"column":25,"nodeType":"601","endLine":410,"endColumn":64},{"ruleId":"599","severity":1,"message":"600","line":413,"column":25,"nodeType":"601","endLine":413,"endColumn":64},{"ruleId":"599","severity":1,"message":"600","line":416,"column":25,"nodeType":"601","endLine":416,"endColumn":64},{"ruleId":"599","severity":1,"message":"600","line":424,"column":25,"nodeType":"601","endLine":424,"endColumn":61},{"ruleId":"599","severity":1,"message":"600","line":30,"column":19,"nodeType":"601","endLine":30,"endColumn":68},"jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","JSXOpeningElement","jsx-a11y/alt-text","Invalid alt value for img. Use alt=\"\" for presentational images.","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","no-script-url","Script URL is a form of eval.","Literal","unexpectedScriptURL","jsx-a11y/anchor-has-content","Anchors must have content and the content must be accessible by a screen reader.","eqeqeq","Expected '===' and instead saw '=='.","BinaryExpression","unexpected","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" (which implies rel=\"noopener\") is a security risk in older browsers: see https://mathiasbynens.github.io/rel-noopener/#recommendations","noTargetBlankWithoutNoreferrer",{"range":"624","text":"625"},{"range":"626","text":"625"},{"range":"627","text":"625"},{"range":"628","text":"625"},[13368,13368]," rel=\"noreferrer\"",[13639,13639],[13939,13939],[14218,14218]]